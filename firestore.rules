rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'adiprabhawale@gmail.com';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    match /trips/{tripId} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /trips/{tripId}/{document=**} {
      allow read, write: if isAdmin() || request.auth != null;
    }
  }
}
